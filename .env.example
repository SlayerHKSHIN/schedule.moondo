# Server Configuration
PORT=4312
NODE_ENV=production
APP_ORIGIN=https://schedule.moondo.ai

# Application secrets (use distinct, high-entropy values in production)
SESSION_SECRET=replace-with-a-random-session-secret
JWT_SECRET=replace-with-a-random-jwt-secret
ADMIN_SESSION_SECRET=replace-with-a-random-admin-session-secret
BOOKING_MANAGEMENT_SECRET=replace-with-a-distinct-random-secret-of-at-least-32-characters
BOOKING_LINK_REQUEST_COOLDOWN_MS=600000

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# Google Calendar Configuration
GOOGLE_CALENDAR_ID=your-email@gmail.com

# Admin Authentication
ADMIN_PASSWORD=your-secure-admin-password

# Encryption Key (generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-64-character-hex-encryption-key
